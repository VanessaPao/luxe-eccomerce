rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────
    // Funciones de ayuda
    // ─────────────────────────────────────────────────────────

    // Verifica si el usuario está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Verifica si el usuario accede a su propio recurso
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Verifica si el usuario tiene rol de administrador
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // ─────────────────────────────────────────────────────────
    // Colección: users/{uid}
    // ─────────────────────────────────────────────────────────
    match /users/{uid} {
      // El usuario puede leer y actualizar su propio perfil
      allow read, update: if isOwner(uid);
      // Solo se puede crear al registrarse (desde auth.js o Functions)
      allow create: if isOwner(uid);
      // Solo el admin puede leer cualquier usuario
      allow read: if isAdmin();
      // Nadie puede eliminar usuarios desde el cliente
      allow delete: if false;

      // Subcolección: carrito del usuario
      match /cart/{itemId} {
        allow read, write: if isOwner(uid);
      }

      // Subcolección: favoritos del usuario
      match /favourites/{itemId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ─────────────────────────────────────────────────────────
    // Colección: products/{productId}
    // ─────────────────────────────────────────────────────────
    match /products/{productId} {
      // Cualquier visitante puede ver los productos
      allow read: if true;
      // Solo el administrador puede crear, editar y eliminar productos
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // Colección: orders/{orderId}
    // ─────────────────────────────────────────────────────────
    match /orders/{orderId} {
      // El usuario puede leer solo sus propias órdenes
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      // El admin puede leer todas las órdenes
      allow read: if isAdmin();
      // Las órdenes solo se crean y actualizan desde Cloud Functions (Admin SDK)
      // El Admin SDK bypasea estas reglas, por eso ponemos false en cliente
      allow write: if false;
    }

    // ─────────────────────────────────────────────────────────
    // Colección: pending_orders/{sessionId}
    // ─────────────────────────────────────────────────────────
    match /pending_orders/{sessionId} {
      // Solo Cloud Functions (Admin SDK) puede leer/escribir aquí
      // El cliente nunca accede a esta colección directamente
      allow read, write: if false;
    }

  }
}
